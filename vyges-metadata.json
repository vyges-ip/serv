{
  "$schema": "https://vyges.com/schema/v1/vyges-metadata.schema.json",
  "name": "serv",
  "version": "1.3.0",
  "description": "SERV — the world's smallest RISC-V CPU. Bit-serial architecture processes one bit per cycle, achieving minimal area (~200 LUTs on FPGA, ~2,000 gates ASIC). Implements RV32I base integer ISA with optional M, C, Zicsr extensions. Ideal for area-constrained designs, IoT sensor nodes, and massively parallel compute arrays.",
  "license": "ISC",
  "maturity": "production",
  "target": ["asic", "fpga"],
  "design_type": ["digital"],
  "created": "2018-01-01T00:00:00Z",
  "updated": "2026-04-02T05:25:08Z",
  "source": {
    "type": "git",
    "url": "https://github.com/olofk/serv",
    "private": false,
    "rtl_path": "rtl"
  },
  "interfaces": [
    {
      "type": "clock",
      "signals": [{"name": "clk", "direction": "input", "width": 1}]
    },
    {
      "type": "reset",
      "signals": [{"name": "i_rst", "direction": "input", "width": 1}]
    },
    {
      "type": "bus",
      "protocol": "wishbone",
      "description": "Instruction bus (Wishbone B3)",
      "signals": [
        {"name": "o_ibus_adr", "direction": "output", "width": 32},
        {"name": "o_ibus_cyc", "direction": "output", "width": 1},
        {"name": "i_ibus_rdt", "direction": "input", "width": 32},
        {"name": "i_ibus_ack", "direction": "input", "width": 1}
      ]
    },
    {
      "type": "bus",
      "protocol": "wishbone",
      "description": "Data bus (Wishbone B3)",
      "signals": [
        {"name": "o_dbus_adr", "direction": "output", "width": 32},
        {"name": "o_dbus_dat", "direction": "output", "width": 32},
        {"name": "o_dbus_sel", "direction": "output", "width": 4},
        {"name": "o_dbus_we", "direction": "output", "width": 1},
        {"name": "o_dbus_cyc", "direction": "output", "width": 1},
        {"name": "i_dbus_rdt", "direction": "input", "width": 32},
        {"name": "i_dbus_ack", "direction": "input", "width": 1}
      ]
    }
  ],
  "parameters": [
    {"name": "RESET_PC", "type": "int", "default": "32'h00000000", "description": "Reset vector address"},
    {"name": "WITH_CSR", "type": "int", "default": "1", "description": "Enable CSR support (Zicsr)"},
    {"name": "MDU", "type": "int", "default": "0", "description": "Enable M extension (multiply/divide)"},
    {"name": "COMPRESSED", "type": "int", "default": "0", "description": "Enable C extension (compressed instructions)"},
    {"name": "ALIGN", "type": "int", "default": "0", "description": "Enable sub-word alignment logic"},
    {"name": "RF_WIDTH", "type": "int", "default": "2", "description": "Register file read width (bits per cycle)"}
  ],
  "rtl_files": [
    "rtl/serv_alu.v", "rtl/serv_aligner.v", "rtl/serv_bufreg.v", "rtl/serv_bufreg2.v",
    "rtl/serv_compdec.v", "rtl/serv_csr.v", "rtl/serv_ctrl.v", "rtl/serv_debug.v",
    "rtl/serv_decode.v", "rtl/serv_immdec.v", "rtl/serv_mem_if.v", "rtl/serv_rf_if.v",
    "rtl/serv_rf_ram.v", "rtl/serv_rf_ram_if.v", "rtl/serv_rf_top.v", "rtl/serv_state.v",
    "rtl/serv_synth_wrapper.v", "rtl/serv_top.v"
  ],
  "rtl_quality": {
    "module_prefixed": true,
    "defines_prefixed": true,
    "header_guards": true,
    "one_module_per_file": true,
    "self_contained_includes": true,
    "no_translate_pragmas": true,
    "lint_clean": true,
    "no_casex": true,
    "width_clean": true,
    "no_sv_keyword_conflicts": true
  },
  "defines": [],
  "categories": {
    "primary": "Processing Cores",
    "secondary": ["risc-v", "area-optimized"],
    "tags": ["risc-v", "rv32i", "bit-serial", "minimal", "area-optimized", "wishbone", "iot"]
  },
  "trust": {
    "verification_level": "production",
    "tapeout_count": 5,
    "fpga_validated": true,
    "maintained": true
  },
  "branding": {
    "display_name": "SERV"
  }
}
